rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userHostelIdFromUsuarioDoc() {
      let d = get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
      return !d.exists ? null
        : d.data.hostelId == null ? null
        : (d.data.hostelId is string && d.data.hostelId.size() == 0) ? null
        : d.data.hostelId;
    }

    function userHostelIdFromUsuarioAfterRequest() {
      let d = getAfter(/databases/$(database)/documents/usuarios/$(request.auth.uid));
      return !d.exists ? null
        : d.data.hostelId == null ? null
        : (d.data.hostelId is string && d.data.hostelId.size() == 0) ? null
        : d.data.hostelId;
    }

    function userHostelId() {
      return isSignedIn() ? userHostelIdFromUsuarioDoc() : null;
    }

    function isUsersHostel(hostelId) {
      return isSignedIn() && userHostelId() == hostelId;
    }

    match /usuarios/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Rutas explícitas (evita problemas de list/query con {document=**} anidado).
    match /hostels/{hostelId} {
      allow create: if isSignedIn() && userHostelIdFromUsuarioAfterRequest() == null;
      allow read, update, delete: if isUsersHostel(hostelId);

      match /plantas/{plantaId} {
        allow read, write: if isUsersHostel(hostelId);

        match /espacios/{espacioId} {
          allow read, write: if isUsersHostel(hostelId);

          match /camas/{camaId} {
            allow read, write: if isUsersHostel(hostelId);
          }
        }
      }

      match /reservas/{reservaId} {
        allow read, write: if isUsersHostel(hostelId);
      }

      match /bloqueos/{bloqueoId} {
        allow read, write: if isUsersHostel(hostelId);
      }
    }
  }
}
