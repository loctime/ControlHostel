rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // hostelId efectivo: sin doc, sin campo, null o string vacío => "sin hostel" (permitir /setup).
    // El cliente debe guardar null (no ""): en reglas Firestore, "" == null es falso y rompe hasNoHostelAssigned.
    // IMPORTANTE: si usuarios/{uid} no existe, NO acceder a .data (falla la regla → permission-denied).
    function userHostelIdFromUsuarioDoc() {
      let d = get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
      return !d.exists ? null
        : d.data.hostelId == null ? null
        : (d.data.hostelId is string && d.data.hostelId.size() == 0) ? null
        : d.data.hostelId;
    }

    // Estado de usuarios/{uid} tras aplicar la petición (batch/transacción o escritura simple).
    // Necesario para allow create en hostels: en un batch, get() no ve el setDoc de usuario todavía.
    function userHostelIdFromUsuarioAfterRequest() {
      let d = getAfter(/databases/$(database)/documents/usuarios/$(request.auth.uid));
      return !d.exists ? null
        : d.data.hostelId == null ? null
        : (d.data.hostelId is string && d.data.hostelId.size() == 0) ? null
        : d.data.hostelId;
    }

    function userHostelId() {
      return isSignedIn() ? userHostelIdFromUsuarioDoc() : null;
    }

    function isUsersHostel(hostelId) {
      return isSignedIn() && userHostelId() == hostelId;
    }

    // Documento del usuario: usuarios/{uid}
    match /usuarios/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      // Setup inicial: el usuario se asigna su hostelId (y puede actualizarlo si hace falta).
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Hostels y subcolecciones
    match /hostels/{hostelId} {
      // Crear hostel: sin hostel asignado tras esta petición (getAfter → coherente con writeBatch + set usuario).
      allow create: if isSignedIn() && userHostelIdFromUsuarioAfterRequest() == null;

      // Lectura/escritura solo dentro del hostel asignado al usuario.
      allow read, update, delete: if isUsersHostel(hostelId);

      // Subcolecciones del hostel (cualquier profundidad)
      match /{document=**} {
        allow read, write: if isUsersHostel(hostelId);
      }
    }
  }
}
